0:["0_Xb0E-hzUGK1SrrtD3Rf",[[["",{"children":["blog",{"children":[["slug","customer-testimonial-feature","d"],{"children":["__PAGE__?{\"slug\":\"customer-testimonial-feature\"}",{}]}]}]},"$undefined","$undefined",true],["",{"children":["blog",{"children":[["slug","customer-testimonial-feature","d"],{"children":["__PAGE__",{},[["$L1",[["$","article",null,{"className":"container py-12","children":[["$","$L2",null,{"article":{"id":"12","slug":"customer-testimonial-feature","title":"Customer Impact: Why Families Choose Oshanodes","excerpt":"Hear from families across West Africa about how Oshanodes Agro products have impacted their health and communities.","content":"Customer stories remind us why we do what we do. Here's what customers are saying:\n\n\"Since switching to Oshanodes rice, my family feels healthier. The taste is noticeably different from mass-produced alternatives.\" - Ama, Ghana\n\n\"I love knowing exactly where my food comes from. I can trust that Oshanodes rice and beans are grown responsibly.\" - Hassan, Nigeria\n\n\"As a restaurant owner, Oshanodes products elevate my dishes. My customers notice the quality difference.\" - Zainab, Benin\n\nThese testimonials reflect our core mission: producing food that nourishes people and communities. Every purchase of Oshanodes products supports sustainable farming and rural development.\n\nWe're grateful for our customers' trust and commitment to better agriculture.","category":"company-news","author":"Oshanodes Team","publishDate":"2024-03-01","readingTime":4,"image":"/images/oshanodes 5.jpg","featured":true}}],["$","div",null,{"className":"mt-10 prose prose-lg max-w-4xl mx-auto","children":["$","$L3",null,{"content":"Customer stories remind us why we do what we do. Here's what customers are saying:\n\n\"Since switching to Oshanodes rice, my family feels healthier. The taste is noticeably different from mass-produced alternatives.\" - Ama, Ghana\n\n\"I love knowing exactly where my food comes from. I can trust that Oshanodes rice and beans are grown responsibly.\" - Hassan, Nigeria\n\n\"As a restaurant owner, Oshanodes products elevate my dishes. My customers notice the quality difference.\" - Zainab, Benin\n\nThese testimonials reflect our core mission: producing food that nourishes people and communities. Every purchase of Oshanodes products supports sustainable farming and rural development.\n\nWe're grateful for our customers' trust and commitment to better agriculture."}]}],["$","$L4",null,{"articles":[{"id":"5","slug":"oshanodes-expansion-announcement","title":"Oshanodes Agro Expansion Announcement","excerpt":"We're thrilled to announce our expansion into three new farming regions across the Benue Valley, creating new opportunities for farmers and customers.","content":"We are excited to announce a major expansion of Oshanodes Agro operations. Starting this season, we are establishing farming operations in three new regions within the Benue Valley.\n\nThis expansion represents our commitment to scaling sustainable agriculture while creating economic opportunities for local farming communities. Each new region will employ 50+ farmers and create value-added processing jobs.\n\nThe expansion includes investment in modern processing facilities, farmer training programs, and community development initiatives. We expect to increase our rice and bean production by 40% while maintaining our strict quality and sustainability standards.\n\nThis growth positions Oshanodes Agro to serve more customers across West Africa while deepening our positive community impact.","category":"company-news","author":"Oshanodes Communications","publishDate":"2024-06-10","readingTime":4,"image":"/images/oshanodes 7.jpg"}]}]]}],["$","section",null,{"className":"bg-gray-50 py-12 mt-12","children":["$","div",null,{"className":"container","children":["$","div",null,{"className":"grid md:grid-cols-2 gap-6","children":[["$","$L5",null,{"href":"/blog/climate-resilient-farming","className":"p-6 bg-white 