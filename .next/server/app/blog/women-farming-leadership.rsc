0:["0_Xb0E-hzUGK1SrrtD3Rf",[[["",{"children":["blog",{"children":[["slug","women-farming-leadership","d"],{"children":["__PAGE__?{\"slug\":\"women-farming-leadership\"}",{}]}]}]},"$undefined","$undefined",true],["",{"children":["blog",{"children":[["slug","women-farming-leadership","d"],{"children":["__PAGE__",{},[["$L1",[["$","article",null,{"className":"container py-12","children":[["$","$L2",null,{"article":{"id":"10","slug":"women-farming-leadership","title":"Women in Agriculture Leadership","excerpt":"Celebrating the women farmers and agricultural leaders driving innovation and sustainability in West African farming.","content":"Women play a critical role in agriculture, yet often face unique challenges in access to resources, credit, and market opportunities. At Oshanodes Agro, we're committed to empowering women farmers.\n\nOur initiatives include:\n- Women-focused training programs\n- Access to credit and equipment financing\n- Women's farmer cooperatives\n- Leadership development\n- Fair pricing and guaranteed markets\n\nWomen bring innovation, resilience, and community focus to agriculture. When we empower women farmers, we create positive ripple effects across entire communities.\n\nThe women in our network are proof that gender equity and agricultural success go hand-in-hand.","category":"community-stories","author":"Folake Adeniyi","publishDate":"2024-03-28","readingTime":5,"image":"/images/oshanodes 13.jpg"}}],["$","div",null,{"className":"mt-10 prose prose-lg max-w-4xl mx-auto","children":["$","$L3",null,{"content":"Women play a critical role in agriculture, yet often face unique challenges in access to resources, credit, and market opportunities. At Oshanodes Agro, we're committed to empowering women farmers.\n\nOur initiatives include:\n- Women-focused training programs\n- Access to credit and equipment financing\n- Women's farmer cooperatives\n- Leadership development\n- Fair pricing and guaranteed markets\n\nWomen bring innovation, resilience, and community focus to agriculture. When we empower women farmers, we create positive ripple effects across entire communities.\n\nThe women in our network are proof that gender equity and agricultural success go hand-in-hand."}]}],["$","$L4",null,{"articles":[{"id":"6","slug":"farmers-cooperative-success-story","title":"Farmers Cooperative Success Story","excerpt":"Meet the smallholder farmers in the Benue Valley whose lives have been transformed through our cooperative farming model.","content":"Maria and her neighbors have been farming rice and beans for generations, but it wasn't until joining the Oshanodes cooperative that their lives truly transformed.\n\nThrough the cooperative model, small farmers gain access to modern tools, training, and fair market prices. Instead of selling to middlemen at low prices, cooperative members sell directly to Oshanodes at rates that fairly compensate their work.\n\nThe cooperative also provides education on sustainable farming, soil management, and post-harvest handling. Members share equipment and knowledge, reducing individual costs while improving outcomes.\n\nOver the past two years, Maria has doubled her harvest while reducing her input costs. She's invested in her children's education and improved her family's home. Her story is just one of hundreds in the Oshanodes cooperative network.","category":"community-stories","author":"Samuel Okonkwo","publishDate":"2024-05-10","readingTime":5,"image":"/images/oshanodes 8.jpg"}]}]]}],["$","section",null,{"className":"bg-gray-50 py-12 mt-12","children":["$","div",null,{"className":"container","children":["$","div",null,{"className":"grid md:grid-cols-2 gap-6","children":[["$","$L5",null,{"href":"/blog/bean-varieties-guide","className":"p-6 bg-white rounded-lg hover:shadow-lg transition-shadow","children":[["$","p",null,{"className":"text-sm text-slate-500 mb-2","children":"← Previous Article"}],["$","h3",null,{"className":"font-bold hover:text-primary transition-colors","children":