0:["0_Xb0E-hzUGK1SrrtD3Rf",[[["",{"children":["blog",{"children":[["slug","climate-resilient-farming","d"],{"children":["__PAGE__?{\"slug\":\"climate-resilient-farming\"}",{}]}]}]},"$undefined","$undefined",true],["",{"children":["blog",{"children":[["slug","climate-resilient-farming","d"],{"children":["__PAGE__",{},[["$L1",[["$","article",null,{"className":"container py-12","children":[["$","$L2",null,{"article":{"id":"11","slug":"climate-resilient-farming","title":"Climate-Resilient Farming Practices","excerpt":"Adapting farming practices to build resilience against changing climate patterns while maintaining productivity.","content":"Climate change poses significant challenges to agriculture. Building resilience requires diverse strategies and adaptive management.\n\nClimate-resilient practices include:\n- Diversified crop production\n- Water harvesting and storage\n- Improved seed varieties\n- Mulching and soil conservation\n- Forest integration (agroforestry)\n\nThese practices reduce vulnerability to drought, flooding, and temperature extremes. At Oshanodes Agro, we're investing in climate adaptation to ensure long-term productivity and farmer livelihoods.\n\nOur commitment to resilience benefits farmers, consumers, and the planet.","category":"sustainability","author":"Dr. Chukwudi Okafor","publishDate":"2024-03-15","readingTime":7,"image":"/images/oshanodes 14.jpg"}}],["$","div",null,{"className":"mt-10 prose prose-lg max-w-4xl mx-auto","children":["$","$L3",null,{"content":"Climate change poses significant challenges to agriculture. Building resilience requires diverse strategies and adaptive management.\n\nClimate-resilient practices include:\n- Diversified crop production\n- Water harvesting and storage\n- Improved seed varieties\n- Mulching and soil conservation\n- Forest integration (agroforestry)\n\nThese practices reduce vulnerability to drought, flooding, and temperature extremes. At Oshanodes Agro, we're investing in climate adaptation to ensure long-term productivity and farmer livelihoods.\n\nOur commitment to resilience benefits farmers, consumers, and the planet."}]}],["$","$L4",null,{"articles":[{"id":"3","slug":"building-healthier-food-system","title":"Building a Healthier Food System","excerpt":"Exploring how sustainable agricultural practices contribute to food security, nutrition, and community health across West Africa.","content":"A healthier food system starts with how we grow food. Industrial agriculture prioritizes yield over quality, often at the expense of nutrition and environmental health.\n\nOshanodes Agro believes that sustainable agriculture creates nutritionally superior products. When we avoid synthetic pesticides and chemical fertilizers, our crops develop stronger nutritional profiles naturally.\n\nOur commitment to sustainability also ensures consistent food supply, reduces waste, and builds resilient farming communities. By investing in smallholder farmers and cooperative models, we're creating a food system that nourishes both people and the planet.\n\nThis is not just about individual products—it's about transforming the entire food system.","category":"sustainability","author":"Dr. Amara Adeyemi","publishDate":"2024-05-20","readingTime":7,"image":"/images/oshanodes 5.jpg"},{"id":"8","slug":"water-conservation-rice-farming","title":"Water Conservation in Rice Farming","excerpt":"Innovative irrigation techniques that reduce water usage by 40% while maintaining optimal yields in rice production.","content":"Rice farming traditionally requires significant water resources. However, innovative irrigation techniques can substantially reduce water usage while maintaining crop health.\n\nDrip irrigation systems deliver water directly to plant roots, reducing evaporation and runoff. Alternate wetting and drying (AWD) techniques allow soil to dry between waterings, encouraging deeper root development while conserving water.\n\nAt Oshanodes Agro, we've implemented these techniques across our operations, reducing water usage by 40% compared to traditional flooding methods. This has particular importance as water scarcity becomes an increasing challenge.\n\nThese practices benefit both our bottom line and the environment.","category":"sustainability","author":"Emeka Nwosu","publishDate":"2024-04-15","readingTime":5,"image":"/images/oshanodes 11.jpg"}]}]]}],["$","section",null,{"className":"bg-gray-50 py-12 mt-12","children":["$","div",null,{"className":"container","children":["$","div",null,{"className":"grid md:grid-cols-2 gap-6","children":[["$","$L5",null,{"href":"/blog/women-farming-leadership","className":"p-6 bg-white rounded-lg hover:shadow-lg transition-shadow","children":[["$","p",null,{"className":"text-sm text-slate-500 mb-2","children":"← Previous Article"}],["$","h3",null,{"className":"font-bold hover:text-primary transition-colors","children":"Women in Agriculture Leadership"}]]}],["$","$L5",null,{"href":"/blog/customer-testimonial-feature","className":"p-6 bg-white rounded-lg hover:shadow-lg transition-shadow md:text-right","children":[["$","p",null,{"className":"text-sm text-slate-500 mb-2","children":"Next Article →"}],["$","h3",null,{"className":"font-bold hover:text-primary transition-colors","children":"Customer Impact: Why Families Choose Oshanodes"}]]}]]}]}]}]],null],null],null]},[null,["$","$L6",null,{"parallelRouterKey":"children","segmentPath":["children","blog","children","$7","children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L8",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","notFoundStyles":"$undefined"}]],null]},[null,["$","$L6",null,{"parallelRouterKey":"children","segmentPath":["children","blog","children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L8",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","notFoundStyles":"$undefined